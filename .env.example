GEMINI_API_KEY=your_gemini_api_key_here

# Optional model overrides
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# Optional local runtime settings
APP_NAME=RAG Adaptive Learning App
API_PREFIX=/api
MAX_UPLOAD_MB=30
TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
CODE_TIMEOUT_SECONDS=5

# Optional path overrides. Relative paths are resolved from the project root.
DATABASE_PATH=backend/data/learning.db
UPLOAD_DIR=backend/data/uploads
FAISS_INDEX_DIR=backend/data/faiss
